PORT=4000
NODE_ENV=development

# PostgreSQL (required for API data access)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insurexp

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=8h

# Optional: Redis (sessions, queues — wire when needed)
REDIS_URL=redis://localhost:6379

# CORS: Next.js dev server
FRONTEND_ORIGIN=http://localhost:3000
